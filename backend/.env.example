# 服务端口（Railway 会自动注入 PORT，本地默认 3001）
PORT=3001

# 前端站点地址（Railway 双服务部署时填前端公网 URL，用于 CORS）
# 云服务器单进程部署（后端托管 dist）可留空
# FRONTEND_URL=https://你的前端域名.up.railway.app

# 后端公网根地址（不含 /api），上传接口返回完整图片 URL 时使用
# 云服务器单进程部署建议填写，例如 https://your-domain.com
# PUBLIC_BASE_URL=https://your-domain.com

# 云服务器单进程部署：构建 frontend/dist 后 backend 自动托管页面与 /api（默认开启）
# 仅 API 服务（Railway 后端）时设为 false
# SERVE_FRONTEND=false

# 自定义前端构建目录（默认 ../frontend/dist）
# FRONTEND_DIST=/var/www/heritage/frontend/dist

# 数据持久化（Railway 必须挂载 Volume，否则重启后图片和数据库会丢失）
# 在 Railway 后端服务添加 Volume，挂载路径例如 /data，然后设置：
# DB_PATH=/data/heritage.db
# UPLOAD_DIR=/data/uploads

# JWT 密钥（生产环境请修改）
JWT_SECRET=heritage-lacquer-museum-secret-key-2024

# ========== 大语言模型 API（OpenAI 兼容格式）==========
# 在 https://platform.deepseek.com 或对应平台申请 API Key
LLM_API_KEY=sk-5c891350d6ce453ab1fc1f2b41fa9eef

# API 地址（DeepSeek 默认如下，OpenAI 改为 https://api.openai.com）
LLM_API_BASE_URL=https://api.deepseek.com

# 模型名称（DeepSeek: deepseek-chat；OpenAI: gpt-4o-mini 等）
LLM_MODEL=deepseek-chat

# 请求超时（毫秒）
LLM_TIMEOUT=60000

# 李囡作品爬虫（启动时自动运行，设为 false 可关闭）
# CRAWL_LINAN_WORKS=true
LLM_USE_OLLAMA=false

# 以下仅在 LLM_USE_OLLAMA=true 时生效
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1:8b

# 平台统计基数（可选）
# PLATFORM_USER_BASE=1560
# PLATFORM_PAGEVIEW_BASE=246000
