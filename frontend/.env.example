# 本地开发留空即可（Vite 代理 /api、/uploads -> localhost:3001）
# VITE_API_BASE_URL=

# ========== 云服务器单进程部署（推荐）==========
# 构建后由 backend 托管 dist，/api 与页面同源，无需 Nginx 单独转发 /api
# 1. cd frontend && npm run build
# 2. cd backend && npm start
# 3. Nginx 反代到 3001 端口（见 deploy/nginx.conf.example）
#
# ========== Railway 双服务部署 ==========
# 推荐方式：设置 BACKEND_URL（运行时），由 server.mjs 代理 /api 和 /uploads
# BACKEND_URL=https://你的后端域名.up.railway.app

# 备选方式：构建时直连后端（需重新 Build）
# VITE_API_BASE_URL=https://你的后端域名.up.railway.app/api
# VITE_API_ORIGIN=https://你的后端域名.up.railway.app
